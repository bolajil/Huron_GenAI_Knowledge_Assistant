# =============================================================================
# Huron GenAI Knowledge Assistant - Production .gitignore
# Phase 0 Security Cleanup - May 2026
# =============================================================================

# =============================================================================
# CRITICAL SECURITY - Personal/Sensitive Documents
# =============================================================================
# NEVER commit personal documents
**/uploads/
uploads/
archive_cleanup_*/uploads/

# Sensitive document patterns
*social-security*
*checkstub*
*paystub*
*pay-stub*
*w-4*
*w4*
*direct-deposit*
*_DD.pdf
*resume*.pdf
*tax*.pdf

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.env
*.env.bak
!.env.example

# Streamlit secrets
.streamlit/secrets.toml
.streamlit/

# Config secrets
config/storage.env
config/*.env
config/*.env.bak
!config/*.env.example
!config/*.yml

# Encryption keys (generated locally)
app/auth/.encryption_key

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv/

# =============================================================================
# IDE & Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# =============================================================================
# Database Files
# =============================================================================
*.db
*.sqlite
*.sqlite3
mcp_logs.db

# =============================================================================
# Logs & Temp Files
# =============================================================================
*.log
logs/
*.tmp
*.temp
*.bak
*.backup
*.old

# =============================================================================
# Node.js / Frontend
# =============================================================================
node_modules/
package-lock.json
.next/
out/
.vercel/
.turbo/

# =============================================================================
# Testing & Coverage
# =============================================================================
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.tox/

# =============================================================================
# Type Checkers
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# =============================================================================
# ML/AI Model Files (Large)
# =============================================================================
*.pkl
*.h5
*.pt
*.pth
*.onnx
*.bin
model_snapshot/

# =============================================================================
# Vector Store Indices (Rebuild locally)
# =============================================================================
faiss_index/
indexes/
*.index
*.faiss

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Archives & Cleanup
# =============================================================================
archive_cleanup_*/
archive_*/
_archived/

# =============================================================================
# Development Scripts (keep in repo but ignore local variants)
# =============================================================================
# Uncomment below if you want to ignore all test/debug files:
# test_*.py
# debug_*.py
# fix_*.py

# =============================================================================
# Build Artifacts
# =============================================================================
*.pyc
*.pyo
*.pyd
*.dll
*.dylib

# =============================================================================
# Backups
# =============================================================================
backups/
*.backup
*.tfvars
*.tfstate
*.tfstate.backup
.terraform/
